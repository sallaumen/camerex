<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark" style="color-scheme: dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Camerex" suffix=" · Phoenix Framework" phx-no-format>{assigns[:page_title]}</.live_title>
    <link
      rel="preload"
      href={~p"/fonts/newsreader-latin-wght-normal.woff2"}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-cx-bg text-cx-text antialiased">
    {@inner_content}
  </body>
</html>
